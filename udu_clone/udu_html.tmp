                    <section id="tai_lieu_dao_tao">
                        <h3 style="color: var(--primary)">Tài liệu đào tạo</h3>
                        <div></div>
                    </section>
                </div>
            </div> 
		</div>
			</div>
</div>

<script>

    const sections = document.querySelectorAll("section");
    const navLi = document.querySelectorAll("ul.vertical-tab li a");

    window.addEventListener("scroll", () => {
        let current = "";
        sections.forEach((section) => {
            const sectionTop = section.offsetTop;
            const sectionHeight = section.clientHeight;
            if (pageYOffset+100 >= sectionTop) {
                current = section.getAttribute("id");
            }
        });

        if(current) {
            navLi.forEach((li) => {
            if (li.getAttribute('tab') == current) {
                li.classList.add("active");
            } else {
                li.classList.remove("active");
            }
        });
        }
    });

    // navLi.forEach((li) => {
    //     li.addEventListener('click', e => {
    //         document.querySelector("ul.vertical-tab li a.active")?.classList.remove('active');
    //         e.target.classList.add('active');
    //     })
    // })

    const navChuyenNghanh = document.querySelectorAll('#cau_truc_chuong_trinh ul.nav-tab li');
    document.querySelectorAll("#cau_truc_chuong_trinh ul.nav-tab li")[0].classList.add('active');
    document.querySelectorAll("#cau_truc_chuong_trinh .tab-content")[0].classList.add('active');
    navChuyenNghanh.forEach((li) => {
        li.addEventListener('click', e => {
            document.querySelector("#cau_truc_chuong_trinh ul.nav-tab li.active")?.classList.remove('active');
            e.target.classList.add('active');
            document.querySelector("#cau_truc_chuong_trinh .tab-content.active")?.classList.remove('active');
            const tabActive = e.target.getAttribute("tab");
            if(!tabActive) return;
            let elementActive = document.getElementById(tabActive);
            elementActive?.classList.add('active');
        })
    })
</script>			</div> <!-- /Inside Content -->
