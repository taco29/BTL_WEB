<main id="main-content">
      <div class="contact-banner research-banner">
        <div class="contact-banner-overlay">
          <div class="contact-breadcrumb">
            <a href="/udu_clone/index.html"><i class="fa-solid fa-house-chimney"></i></a>
            <i class="fa-solid fa-angle-right"></i>
            <a href="/udu_clone/pages/hoat-dong-sinh-vien.html"><span>Giới thiệu</span></a>
            <i class="fa-solid fa-angle-right"></i>
            <span>Đội ngũ giảng viên</span>
          </div>
          <h1 class="contact-banner-title">Đội ngũ giảng viên</h1>
        </div>
      </div>
      <div class="anhtenlabang">
        <div class="container-gioi-thieu">
          <div class="gioi-thieu-chung">
            <div class="lecturer-grid">
              {{#each staffs}}
              <div class="lecturer-card">
                <div class="lecturer-img">
                  <img src="{{this.avatar}}" alt="{{this.name}}">
                </div>
                <div class="lecturer-info">
                  <div class="lecturer-name">{{this.degree}} {{this.name}}</div>
                  <div class="lecturer-divider"></div>
                  <div class="lecturer-role">
                    {{this.position}}; {{this.department}}
                  </div>
                </div>
              </div>
              {{/each}}
            </div>
          </div>
          <div class="sidebar-wrap">
            <ul class="sidebar-menu" id="sidebarMenu">
              <li class="">
                <a href="/gioi-thieu/gioi-thieu-chung">Giới thiệu chung</a>
              </li>
              <li class="bigger">
                <a href="/gioi-thieu/triet-ly-gd-dau-an-dao-tao">Triết lý giáo dục &amp; Dấu ấn Đào tạo</a>
              </li>
              <li class="bigger">
                <a href="/gioi-thieu/lich-su-hinh-thanh-pt">Lịch sử hình thành &amp; phát triển</a>
              </li>
              <li class="active">
                <a href="/gioi-thieu/doi-ngu-giang-vien">Đội ngũ giảng viên</a>
              </li>
              <li>
                <a href="/gioi-thieu/co-cau-to-chuc">Cơ cấu tổ chức</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </main>