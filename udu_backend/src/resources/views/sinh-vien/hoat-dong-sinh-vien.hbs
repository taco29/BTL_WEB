<main id="main-content">
      <div class="contact-banner research-banner">
        <div class="contact-banner-overlay">
          <div class="contact-breadcrumb">
            <a href="/udu_clone/index.html"><i class="fa-solid fa-house-chimney"></i></a>
            <i class="fa-solid fa-angle-right"></i>
            <a href="/udu_clone/pages/hoat-dong-sinh-vien.html"><span>Sinh viên</span></a>
            <i class="fa-solid fa-angle-right"></i>
            <span>Hoạt động sinh viên</span>
          </div>
          <h1 class="contact-banner-title">Hoạt động sinh viên</h1>
        </div>
      </div>
      <div class="container">
        <div class="event-content">
          {{#each activities}}
          <div class="event-card">
            <div class="event-card-img-wrapper">
              <img src="{{this.thumbnail}}" alt="{{this.title}}" class="event-card-img">
            </div>
            <div class="event-card-content">
              <h3 class="event-card-title">
                <a href="/news/{{this.slug}}">{{this.title}}</a>
              </h3>
            </div>
          </div>
          {{/each}}
        </div>

        <div class="pagination">
          {{{pagination currentPage totalPages}}}
        </div>
      </div>
    </main>