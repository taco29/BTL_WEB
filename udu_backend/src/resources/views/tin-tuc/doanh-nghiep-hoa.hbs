<main id="main-content">
      <div class="contact-banner research-banner">
        <div class="contact-banner-overlay">
          <div class="contact-breadcrumb">
            <a href="/udu_clone/index.html"><i class="fa-solid fa-house-chimney"></i></a>
            <i class="fa-solid fa-angle-right"></i>
            <a href="/udu_clone/pages/tin-tuc-html/cchoa.html"><span>Doanh nghiệp hoá</span></a>
            <i class="fa-solid fa-angle-right"></i>
          </div>
          <h1 class="contact-banner-title">Doanh nghiệp hoá</h1>
        </div>
      </div>
      <div class="anhtenlabang">
        <!-- Thanh tìm kiếm -->
        <div class="news-search">
          <input type="text" placeholder="Nhập thông tin tìm kiếm">
          <select>
            <option value="">Sắp xếp theo ...</option>
            <option value="date-desc">Mới nhất</option>
            <option value="date-asc">Cũ nhất</option>
          </select>
          <button>Tìm kiếm</button>
        </div>

        <!-- Grid bài viết -->
        <div class="news-grid">
          {{#each news}}
          <div class="box1">
            <div class="box1-img">
              <img src="{{this.thumbnail}}" alt="Thumbnail">
            </div>
            <div class="box1-content">
              <div class="date">
                <div class="date-icon">
                  <i class="fa-regular fa-calendar" style="color: #bc2626"></i>
                </div>
                <div class="date-text">
                  <span>{{formatDate this.publishedAt}}</span>
                </div>
              </div>
              <div class="wrap">
                <div class="post-title">
                  <span>{{this.title}}</span>
                </div>
              </div>
            </div>
          </div>
          {{/each}}
        </div>

        <div class="pagination">
          {{{pagination currentPage totalPages}}}
        </div>
      </div>
    </main>