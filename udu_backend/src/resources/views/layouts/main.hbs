<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/webp" href="/udu_clone/img/logo-ptit-small.webp">
    <link rel="stylesheet" href="/udu_clone/icon/css_icon/all.min.css">
    <link rel="stylesheet" href="/udu_clone/css/app.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <title>Chương trình Cử nhân Công nghệ thông tin định hướng ứng dụng</title>
</head>

<body>
    <div class="app">
        {{> header}}

        {{{body}}}

        <button id="chatbot-toggle-btn" class="chatbot-btn">
            <span class="chatbot-tooltip">Xin chào! Bạn có câu hỏi nào về PTIT?</span>
            <img src="/udu_clone/img/robot-chatbot-icon-sign-free-vector%20(1).jpg" class="chatbot-icon">
        </button>

        <div id="chatbot-window" class="chatbot-window hidden">
            <div class="chatbot-header">
                Tư vấn tuyển sinh PTIT
                <button id="chatbot-close-btn">&times;</button>
            </div>
            <div id="chatbot-messages" class="chatbot-messages">
                <div class="message bot-message">Chào bạn! Mình có thể giúp gì cho bạn về thông tin tuyển sinh của PTIT?</div>
            </div>
            <div class="chatbot-input">
                <input type="text" id="chatbot-input-field" placeholder="Nhập câu hỏi của bạn...">
                <button id="chatbot-send-btn"><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>

        {{> footer}}
    </div>
    <script src="/udu_clone/js/chatbot.js"></script>
</body>

</html>