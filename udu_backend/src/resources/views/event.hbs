<main id="main-content">
      <div class="contact-banner research-banner">
        <div class="contact-banner-overlay">
          <div class="contact-breadcrumb">
            <a href="/"
              ><i class="fa-solid fa-house-chimney"></i
            ></a>
            <i class="fa-solid fa-angle-right"></i>
            <span>Sự kiện</span>
          </div>
          <h1 class="contact-banner-title">Sự kiện</h1>
        </div>
      </div>
      <div class="container">
        <div class="event-content">
          {{#each events}}
          <div class="event-card">
            <div class="event-card-img-wrapper">
              <div class="event-card-date-badge"><span>{{getDay this.eventDetails.dateString}}</span> {{getMonth this.eventDetails.dateString}}</div>
              <img
                src="{{this.thumbnail}}"
                alt="{{this.title}}"
                class="event-card-img"
              />
            </div>
            <div class="event-card-content">
              <div class="event-meta">
                <i class="fa-regular fa-clock"></i> {{formatDate this.publishedAt}} {{this.eventDetails.timeString}}
              </div>
              <h3 class="event-card-title">
                <a href="/news/{{this.slug}}">{{this.title}}</a>
              </h3>
              <div class="event-location">
                <i class="fa-solid fa-location-dot"></i> {{this.eventDetails.location}}
              </div>
            </div>
          </div>
          {{/each}}
        </div>

        <div class="pagination">
          {{{pagination currentPage totalPages}}}
        </div>
      </div>
    </main>