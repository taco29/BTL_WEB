  "learningOutcomes": [
    {
      "lo_id": "LO1",
      "lo_desc": "Hiểu biết và nắm vững kiến thức về Lý luận chính trị, có hiểu biết về Pháp luật; Hiểu biết về an ninh Quốc phòng.",
      "pis": []
    },
    {
      "lo_id": "LO2",
      "lo_desc": "Hiểu biết và nắm vững các kiến thức khoa học công nghệ cơ bản, chuyên ngành, tiếp cận các định hướng ứng dụng về công nghệ phần mềm...",
      "pis": []
    },
    {
      "lo_id": "LO3",
      "lo_desc": "Áp dụng tốt kiến thức cơ bản và chuyên sâu về công nghệ phần mềm, hệ thống thông tin vào phân tích, đánh giá, kết luận giải pháp chính xác...",
      "pis": []
    },
    {
      "lo_id": "LO4",
      "lo_desc": "Áp dụng được kiến thức chuyên môn về công nghệ thông tin như phân tích, thiết kế và quản lý các dự án phần mềm, lập trình và bảo trì hệ thống phần mềm...",
      "pis": []
    },
    {
      "lo_id": "LO5",
      "lo_desc": "Kỹ năng áp dụng các kiến thức, kĩ năng; sử dụng các công cụ khoa học kĩ thuật để nhận biết, phân tích giải quyết các vấn đề thực tiễn...",
      "pis": []
    }
  ],
